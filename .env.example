# 秘密情報はこのファイルに直接書かず、.env に保存してください。
# .env は Git にコミットされません（.gitignore 対象）。
#
# セットアップ:
#   cp .env.example .env
#   .env を編集して実際の API キーを設定
#
# 本番・CI では環境変数で渡すことを推奨します（.env より優先されます）。

# OpenAI API キー（https://platform.openai.com/api-keys で取得）
OPENAI_API_KEY=your-openai-api-key-here

# 任意: デフォルトモデル
OPENAI_MODEL=gpt-4o-mini

# SerpAPI キー（3.2.1 検索ツール用、https://serpapi.com/ で取得）
SERPAPI_API_KEY=your-serpapi-api-key-here

# Mem0 API キー（3.5 ペルソナ用、https://mem0.ai/ で取得）
MEM0_API_KEY=your-mem0-api-key-here

# Tavily API キー（4.2.4 検索ツール用、https://tavily.com/ で取得）
TAVILY_API_KEY=your-tavily-api-key-here
